  if ($10 ~ /^ID=[^;]+;/) {
    sub(/^ID=[^;]+;/, "", $10)
  }

  # 重建attributes：ID=vOTU_1_1; + 后面所有内容（无空格拼接）
  attrs = $9
  if (attrs !~ /;$/) attrs = attrs ";"
  attrs = attrs $10
  for (i=11; i<=NF; i++) attrs = attrs $i

  # 输出标准9列GFF（前8列 + attrs）
  print $1,$2,$3,$4,$5,$6,$7,$8,attrs
}' output.txt > mags_genes_fixed.gff

