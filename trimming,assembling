BEGIN{FS="[[:space:]]+"; OFS="\t"}
{
  # 取第一段ID=vOTU_x_y作为new_id
  if ($9 ~ /^ID=/) {
    new_id = substr($9,4)
    $1 = new_id
  }

  # 删除第二个ID=1_1;（它在$10开头）
  if ($10 ~ /^ID=[^;]+;/) {
    sub(/^ID=[^;]+;/, "", $10)
  }

  # 重建attributes：ID=vOTU_1_1; + 后面所有内容（无空格拼接）
  attrs = $9
  if (attrs !~ /;$/) attrs = attrs ";"
  attrs = attrs $10
  for (i=11; i<=NF; i++) attrs = attrs $i

  # 输出标准9列GFF（前8列 + attrs）
  print $1,$2,$3,$4,$5,$6,$7,$8,attrs
}' output.txt > vOTU_genes_fixed.gff


